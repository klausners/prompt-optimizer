  "type": "module",
  "license": "MIT",
  "author": "Klaus Heringer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klausners/prompt-optimizer.git"
  },
  "homepage": "https://github.com/klausners/prompt-optimizer",
  "keywords": [
    "promptfoo",
    "prompt-optimization",
    "prompt-engineering",
    "llm-eval",
    "ai-eval",
    "prompt-tuning",
    "llm-rubric",
    "automated-prompt-improvement",
    "openai",
    "anthropic",
    "llm"
  ],
  "bin": {
    "prompt-optimizer": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
